{
  "name": "olivas-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/api",
    "packages/web"
  ],
  "scripts": {
    "api": "npm run dev --workspace=packages/api",
    "api:migrate": "npm run migrate --workspace=packages/api",
    "api:seed": "npm run seed --workspace=packages/api",
    "web": "npm run dev --workspace=packages/web",
    "shared": "npm run build --workspace=packages/shared",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d"
  }
}